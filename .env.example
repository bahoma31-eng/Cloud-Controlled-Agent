# ========================
# Cloud Controlled Agent V13 - Environment Variables
# ========================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# --- Required ---
GITHUB_TOKEN=your_github_token_here
GROQ_API_KEY=your_groq_api_key_here

# --- Repository (defaults shown) ---
REPO_OWNER=bahoma31-eng
REPO_NAME=Cloud-Controlled-Agent

# --- AI Provider: GROQ (default) or GITHUB ---
AI_PROVIDER=GROQ
MODEL_ID=llama-3.3-70b-versatile

# --- GitHub Models (only if AI_PROVIDER=GITHUB) ---
AI_GITHUB_TOKEN=your_github_ai_token_here
GITHUB_MODEL=gpt-4o

# --- Agent Behavior ---
POLL_SECONDS=20
COMMAND_TIMEOUT=240
MAX_RETRIES_PER_STEP=3
VERBOSE=0
