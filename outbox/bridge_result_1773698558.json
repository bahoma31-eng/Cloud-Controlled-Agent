  "output": "\"\"\"\r\nConfiguration settings for the Proverbs Extractor project.\r\nAll API keys are loaded from environment variables for security.\r\n\"\"\"\r\n\r\n\r\nimport os\r\nfrom pathlib import Path\r\nfrom dotenv import load_dotenv\r\n\r\n\r\n# Load environment variables from .env file\r\nload_dotenv()\r\n\r\n\r\n# =============================================================================\r\n# API KEYS (Environment Variables)\r\n# =============================================================================\r\nGOOGLE_BOOKS_API_KEY = os.getenv(\"GOOGLE_BOOKS_API_KEY\")\r\nGEMINI_API_KEY = os.getenv(\"GEMINI_API_KEY\")\r\nGEMINI_API_KEY_2 = os.getenv(\"GEMINI_API_KEY_2\")\r\nGEMINI_API_KEY_3 = os.getenv(\"GEMINI_API_KEY_3\")\r\nGEMINI_API_KEY_4 = os.getenv(\"GEMINI_API_KEY_4\")\r\n\r\n\r\n# Create a list of available keys\r\nGEMINI_API_KEYS = [k for k in [GEMINI_API_KEY, GEMINI_API_KEY_2, GEMINI_API_KEY_3, GEMINI_API_KEY_4] if k]\r\n\r\n\r\nSONAR_API_KEY = os.getenv(\"SONAR_API_KEY\")\r\nSONAR_API_KEY_2 = os.getenv(\"SONAR_API_KEY_2\")\r\nSONAR_API_KEYS = [k for k in [SONAR_API_KEY, SONAR_API_KEY_2] if k]\r\n\r\n\r\n# DeepSeek\r\nDEEPSEEK_API_KEY = os.getenv(\"DEEPSEEK_API_KEY\")\r\nDEEPSEEK_BASE_URL = \"https://api.deepseek.com\"\r\nDEEPSEEK_MODEL = \"deepseek-chat\"\r\n\r\n\r\n# =============================================================================\r\n# GROQ (Free & Fast - OpenAI Compatible)\r\n# =============================================================================\r\nGROQ_API_KEY = os.getenv(\"GROQ_API_KEY\", \"\")\r\nGROQ_API_KEY_2 = os.getenv(\"GROQ_API_KEY_2\", \"\")\r\nGROQ_API_KEY_3 = os.getenv(\"GROQ_API_KEY_3\", \"\")\r\nGROQ_API_KEYS = [k.strip() for k in [GROQ_API_KEY, GROQ_API_KEY_2, GROQ_API_KEY_3] if k and k.strip()]\r\n\r\n# Also support comma-separated keys in a single env var\r\n_groq_keys_csv = os.getenv(\"GROQ_API_KEYS_CSV\", \"\")\r\nif _groq_keys_csv:\r\n    GROQ_API_KEYS.extend([k.strip() for k in _groq_keys_csv.split(\",\") if k.strip()])\r\n    # Remove duplicates while preserving order\r\n    GROQ_API_KEYS = list(dict.fromkeys(GROQ_API_KEYS))\r\n\r\n# Fallback: if list is empty but single key exists\r\nif not GROQ_API_KEYS and GROQ_API_KEY:\r\n    GROQ_API_KEYS = [GROQ_API_KEY]\r\n\r\n\r\n# Maintain backward compatibility - ensure GEMINI_API_KEY is the first valid key if list is valid\r\nif GEMINI_API_KEYS:\r\n    GEMINI_API_KEY = GEMINI_API_KEYS[0]\r\n\r\n\r\n# Setup Key Rotation Logic\r\nimport itertools\r\n_gemini_keys_cycle = itertools.cycle(GEMINI_API_KEYS) if GEMINI_API_KEYS else None\r\n\r\n\r\ndef get_next_gemini_key():\r\n    \"\"\"Get the next Gemini API key in rotation.\"\"\"\r\n    if _gemini_keys_cycle:\r\n        return next(_gemini_keys_cycle)\r\n    return GEMINI_API_KEY\r\n\r\n\r\n# =============================================================================\r\n# SEARCH SETTINGS\r\n# =============================================================================\r\nMAX_SEARCH_RESULTS = 20\r\nSUPPORTED_FORMATS = [\"pdf\", \"epub\"]\r\n\r\n\r\n# Search queries for Arabic proverbs books\r\nSEARCH_QUERIES = [\r\n    \"럝��� ���\"���.�����\" ���\"������S�� ���\"������S��\",\r\n    \"���\"���.�����\" ���\"������S��\",\r\n    \"���.�����\" ������S�� ������S��\",\r\n    \"�.�^���^���� ���\"���.�����\" ���\"������S��\",\r\n    \"Arabic proverbs\",\r\n    \"Arabic folk proverbs collection\",\r\n]\r\n\r\n\r\n# =============================================================================\r\n# DIRECTORY PATHS\r\n# =============================================================================\r\nBASE_DIR = Path(__file__).parent\r\nDATA_DIR = BASE_DIR / \"data\"\r\nBOOKS_DIR = DATA_DIR / \"books\"\r\nOUTPUT_DIR = DATA_DIR / \"output\"\r\nLOGS_DIR = DATA_DIR / \"logs\"\r\n\r\n\r\n# =============================================================================\r\n# API ENDPOINTS\r\n# =============================================================================\r\nGOOGLE_BOOKS_API_URL = \"https://www.googleapis.com/books/v1/volumes\"\r\nINTERNET_ARCHIVE_API_URL = \"https://archive.org/advancedsearch.php\"\r\nOPENLIBRARY_API_URL = \"https://openlibrary.org/search.json\"\r\n\r\n\r\n# =============================================================================\r\n# REQUEST SETTINGS\r\n# =============================================================================\r\nREQUEST_TIMEOUT = 120  # seconds (increased for large file downloads)\r\nREQUEST_DELAY = 1.0   # seconds between API calls to avoid rate limiting\r\nMAX_RETRIES = 3\r\n\r\n\r\n# =============================================================================\r\n# ENSURE DIRECTORIES EXIST\r\n# =============================================================================\r\ndef ensure_directories():\r\n    \"\"\"Create all required directories if they don't exist.\"\"\"\r\n    for directory in [DATA_DIR, BOOKS_DIR, OUTPUT_DIR, LOGS_DIR]:\r\n        directory.mkdir(parents=True, exist_ok=True)\r\n\r\n\r\n# Auto-create directories on import\r\nensure_directories()",
